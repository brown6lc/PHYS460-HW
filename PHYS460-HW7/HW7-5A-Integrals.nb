   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"L", "/", "hbar"}], ")"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "2"}], " ", 
        RowBox[{"Abs", "[", "p", "]"}], " ", 
        RowBox[{"L", "/", "hbar"}]}], "]"}]}], ",", 
