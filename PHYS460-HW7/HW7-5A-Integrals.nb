     RowBox[{
       SuperscriptBox["L", "2"], "\[NotElement]", 
       TemplateBox[{}, "Reals"]}]}]},
  "ConditionalExpression"], "\[IndentingNewLine]", 
 RowBox[{"Assuming", "[", 
